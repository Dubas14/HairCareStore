  server {
      listen 80;
      server_name hairlab.makeweb.top 136.243.150.97;
      client_max_body_size 20M;

      # Media files — serve directly from disk
      location /media/ {
          alias /var/www/HairCareStore/frontend/media/;
          expires 30d;
          add_header Cache-Control "public, must-revalidate";
      }

      # Payload media API — serve directly from disk (bypass sharp)
      location /api/media/file/ {
          alias /var/www/HairCareStore/frontend/media/;
          expires 30d;
          add_header Cache-Control "public, must-revalidate";
      }

      # Static public files
      location /images/ {
          alias /var/www/HairCareStore/frontend/public/images/;
          expires 30d;
      }

      location /logo.png {
          alias /var/www/HairCareStore/frontend/public/logo.png;
          expires 30d;
      }

      location /favicon.ico {
          alias /var/www/HairCareStore/frontend/public/favicon.ico;
          expires 7d;
          access_log off;
      }

      # Next.js static assets
      location /_next/static/ {
          proxy_pass http://127.0.0.1:3200;
          expires 365d;
          add_header Cache-Control "public, immutable";
      }

      # Everything else to Next.js
      location / {
          proxy_pass http://127.0.0.1:3200;
          proxy_http_version 1.1;
          proxy_set_header Upgrade $http_upgrade;
          proxy_set_header Connection 'upgrade';
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Proto $scheme;
          proxy_cache_bypass $http_upgrade;
      }
  }
